generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model AiRecommendation {
  id        String   @id
  role      String   @default("medico")
  prompt    String
  response  String
  createdAt DateTime @default(now())
}

model Appointment {
  id                  String            @id @default(cuid())
  patientId           String
  doctorId            String
  date                DateTime
  time                String
  status              AppointmentStatus @default(PENDING)
  reason              String?
  notes               String?
  whatsappReminder24h Boolean           @default(false)
  whatsappReminder1h  Boolean           @default(false)
  whatsappConfirmed   Boolean           @default(false)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  User                User              @relation(fields: [doctorId], references: [id])
  Patient             Patient           @relation(fields: [patientId], references: [id])

  @@index([date])
  @@index([date, time])
  @@index([doctorId])
  @@index([patientId])
}

model ClinicalVisit {
  id        String   @id @default(cuid())
  patientId String
  doctorId  String
  visitDate DateTime @default(now())
  symptoms  String?
  diagnosis String?
  treatment String?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  User      User     @relation(fields: [doctorId], references: [id])
  Patient   Patient   @relation(fields: [patientId], references: [id])

  @@index([doctorId])
  @@index([patientId])
  @@index([visitDate])
}

model Notification {
  id                String    @id @default(cuid())
  title             String
  content           String
  channel           String    @default("in_app")
  role              String?
  userId            String?
  phone             String?
  whatsappMessageId String?
  sent              Boolean   @default(false)
  sentAt            DateTime?
  read              Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  User              User?     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([role])
  @@index([read])
}

model Patient {
  id              String            @id
  name            String
  phone           String?
  email           String?
  whatsappPhone   String?
  dateOfBirth     DateTime?
  gender          String?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  Appointment     Appointment[]
  ClinicalVisit   ClinicalVisit[]
  PatientFollowUp PatientFollowUp[]
  Prescription    Prescription[]
  TriageReport    TriageReport[]
  WhatsAppMessage WhatsAppMessage[]

  @@index([email])
  @@index([whatsappPhone])
}

model PatientFollowUp {
  id             String         @id @default(cuid())
  patientId      String
  prescriptionId String?        @unique
  startDate      DateTime
  endDate        DateTime?
  status         FollowUpStatus @default(ACTIVE)
  adherenceScore Int            @default(100)
  lastCheckIn    DateTime?
  nextCheckIn    DateTime?
  notes          String?
  alertTriggered Boolean        @default(false)
  alertReason    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  Patient        Patient        @relation(fields: [patientId], references: [id])
  Prescription   Prescription?  @relation(fields: [prescriptionId], references: [id])

  @@index([alertTriggered])
  @@index([nextCheckIn])
  @@index([patientId])
  @@index([status])
}

model PharmacyProduct {
  id                String   @id @default(cuid())
  name              String
  category          String?
  indications       String?
  contraindications String?
  price             Float    @default(0)
  stock             Int      @default(0)
  isAvailable       Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([category])
}

model Prescription {
  id              String                    @id @default(cuid())
  patientId       String
  doctorId        String
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  notes           String?
  productName     String
  dosage          String?
  instructions    String?
  quantity        Int                     @default(1)
  totalPrice      Int                     @default(0)
  billingStatus  PrescriptionBillingStatus @default(PENDING)
  whatsappSent   Boolean                  @default(false)
  Patient         Patient        @relation(fields: [patientId], references: [id])
  User            User           @relation(fields: [doctorId], references: [id])
  PatientFollowUp PatientFollowUp?

  @@index([patientId])
  @@index([doctorId])
  @@index([billingStatus])
}

model Session {
  id           String   @id
  sessionToken String   @unique
  userId       String
  expires      DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model TriageReport {
  id                 String        @id @default(cuid())
  patientId          String?
  phone              String
  symptoms           String
  aiSummary          String?
  urgency            TriageUrgency @default(LOW)
  status             TriageStatus  @default(PENDING)
  aiConfidence       Float         @default(0)
  redFlags           String?
  suggestedQuestions String?
  reviewedAt         DateTime?
  reviewedBy         String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  Patient            Patient?       @relation(fields: [patientId], references: [id])

  @@index([createdAt])
  @@index([status])
  @@index([urgency])
  @@index([patientId])
}

model User {
  id            String          @id @default(cuid())
  email         String          @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String?
  role          UserRole        @default(ADMIN)
  whatsappPhone String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  Account       Account[]
  Appointment   Appointment[]
  ClinicalVisit ClinicalVisit[]
  Notification  Notification[]
  Prescription  Prescription[]
  Session       Session[]

  @@index([email])
  @@index([role])
}

model WhatsAppMessage {
  id           String           @id
  patientId    String?
  phone        String
  direction    MessageDirection
  body         String?
  messageType  MessageType      @default(TEXT)
  templateName String?
  status       MessageStatus    @default(SENT)
  externalId   String?
  error        String?
  intent       String?
  sessionData  String?
  createdAt    DateTime         @default(now())
  Patient      Patient?         @relation(fields: [patientId], references: [id])

  @@index([createdAt])
  @@index([direction])
  @@index([patientId])
  @@index([phone])
  @@index([status])
}

model WhatsAppSession {
  id            String   @id
  phone         String   @unique
  currentIntent String?
  step          String   @default("menu")
  contextData   String
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime

  @@index([expiresAt])
  @@index([phone])
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum FollowUpStatus {
  ACTIVE
  COMPLETED
  NON_ADHERENT
  ALERT
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

enum MessageType {
  TEXT
  TEMPLATE
  INTERACTIVE
  MEDIA
}

enum PrescriptionBillingStatus {
  PENDING
  PREPARED
  BILLED
  DELIVERED
  CANCELLED
}

enum TriageStatus {
  PENDING
  REVIEWED
  ESCALATED
  RESOLVED
}

enum TriageUrgency {
  LOW
  MEDIUM
  HIGH
  EMERGENCY
}

enum UserRole {
  ADMIN
  DOCTOR
  PHARMACIST
}
